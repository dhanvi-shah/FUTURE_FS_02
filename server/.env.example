# Optional locally — Render sets PORT automatically
PORT=5001
MONGODB_URI=mongodb://127.0.0.1:27017/minicrm
JWT_SECRET=your_super_secret_jwt_key_change_in_production
JWT_EXPIRES_IN=7d
# Frontend URL for CORS (required on Render in production)
CLIENT_URL=http://localhost:3001
# Production example: CLIENT_URL=https://your-app.vercel.app
NODE_ENV=development
